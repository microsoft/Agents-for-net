{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/vdevPreview/MicrosoftTeams.schema.json",
  "id": "${{BLUEPRINT_ID}}",
  "name": {
    "short": "sidecar-blueprint-agent Blueprint",
    "full": "sidecar-blueprint-agent Blueprint"
  },
  "description": {
    "short": "sidecar-blueprint-agent",
    "full": "This is a test registration for the sidecar-blueprint-agent agents."
  },
  "icons": {
    "outline": "outline.png",
    "color": "color.png"
  },
  "accentColor": "#9ec9d9",
  "version": "1.0.1",
  "manifestVersion": "devPreview",
  "developer": {
    "name": "Microsoft Corporation",
    "mpnId": "",
    "websiteUrl": "https://go.microsoft.com/fwlink/?LinkId=518028",
    "privacyUrl": "https://go.microsoft.com/fwlink/?LinkId=518028",
    "termsOfUseUrl": "https://shares.datatransfer.microsoft.com/assets/Microsoft_Terms_of_Use.html"
  },
  "agenticUserTemplates": [
    {
      "id": "${{AGENT_TEMPLATE_ID}}",
      "file": "agenticUserTemplateManifest.json"
    }
  ],
  "copilotAgents": {
    "customEngineAgents": [
      {
        "id": "${{BLUEPRINT_ID}}",
        "type": "bot",
        "functionsAs": "agenticUserOnly",
        "agenticUserTemplateId": "${{AGENT_TEMPLATE_ID}}"
      }
    ]
  },
  "bots": [
    {
      "botId": "${{BLUEPRINT_ID}}",
      "scopes": [
        "personal",
        "groupChat",
        "team",
        "copilot"
      ],
      "supportsFiles": true,
      "isNotificationOnly": false,
      "supportsSessions": true,
      "supportsTargetedMessages": true
    }
  ],
  "permissions": [
    "identity",
    "messageTeamMembers"
  ],
  "webApplicationInfo": {
    "id": "${{BLUEPRINT_ID}}",
    "resource": "api://${{BLUEPRINT_ID}}"
  },
  "validDomains": [
    "token.botframework.com"
  ]
}