{
  "TokenValidation": {
    "Enabled": false,
    "Audiences": [
      "{{ClientId}}"
    ],
    "TenantId": "{{TenantId}}"
  },
  "Connections": {
    "ServiceConnection": {
      "Settings": {
        "AuthType": "ClientSecret",
        "AuthorityEndpoint": "https://login.microsoftonline.com/{{TenantId}}",
        "ClientId": "{{ClientId}}",
        "Scopes": [
          "5a807f24-c9de-44ee-a3a7-329e88a00ffc/.default"
        ]
      }
    }
  },
  "ConnectionsMap": [
    {
      "ServiceUrl": "*",
      "Connection": "ServiceConnection"
    }
  ],
  "AgentApplication": {
    "StartTypingTimer": false,
    "RemoveRecipientMention": false,
    "NormalizeMentions": false,
    "UserAuthorization": {
      "AutoSignin": false,
      "Handlers": {
        "me": {
          "Type": "SidecarUserAuthorization",
          "Settings": {
            "SidecarBaseUrl": "http://localhost:5178",
            "ServiceName": "me",
            "Scopes": [
              "User.Read"
            ]
          }
        },
        "agentic": {
          "Type": "AgenticUserAuthorization",
          "Settings": {
            "Scopes": [
              "https://graph.microsoft.com/.default"
            ],
            "AlternateBlueprintConnectionName": "ServiceConnection"
          }
        }
      }
    }
  },
  "Logging": {
    "Debug": {
      "IncludeScopes": true
    },
    "Console": {
      "IncludeScopes": true
    },
    "LogLevel": {
      "Microsoft.Agents": "Debug",
      "Microsoft.Agents.Authentication.Msal.MsalAuth": "Warning",
      "System.Net.Http.HttpClient.MSALClientFactory": "Warning",
      "System.Net.Http.HttpClient.Microsoft.Agents.Builder.RestChannelServiceClientFactory": "Warning",
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Identity": "Warning"
    }
  },
  "EnableAgent365Exporter": false,
  "Agent365Observability": {
    "AgentId": "{{AgentId}}",
    "AgentName": "{{AgentName}}",
    "AgentDescription": "{{AgentDescription}}",
    "TenantId": "{{TenantId}}",
    "AgentBlueprintId": "{{AgentBlueprintId}}",
    "ClientId": "{{ClientId}}"
  }
}