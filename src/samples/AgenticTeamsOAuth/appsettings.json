{
  "TokenValidation": {
    "Enabled": true,
    "Audiences": [
      "{{BlueprintClientId}}"
    ],
    "TenantId": "{{TenantId}}"
  },

  "AgentApplication": {
    "StartTypingTimer": true,
    "RemoveRecipientMention": false,
    "NormalizeMentions": false,
    "UserAuthorization": {
      "AutoSignin": false,
      "Handlers": {
        "agentic": {
          "Type": "TeamsAgenticAuthorization",
          "Settings": {
            "RedirectUri": "https://379b1nwh-3979.usw3.devtunnels.ms/auth/callback",
            "OAuthConnectionName": "UserOAuthConnection",
            "Scopes": [
              "User.Read"
            ]
          }
        }
      }
    }
  },

  "Connections": {
    "BlueprintConnection": {
      "Settings": {
        "AuthType": "ClientSecret",
        "AuthorityEndpoint": "https://login.microsoftonline.com/{{TenantId}}",
        "ClientId": "{{BlueprintClientId}}",
        "ClientSecret": "{{BlueprintClientSecret}}",
        "Scopes": [
          "5a807f24-c9de-44ee-a3a7-329e88a00ffc/.default"
        ]
      }
    },
    "UserOAuthConnection": {
      "Settings": {
        "AuthType": "ClientSecret",
        "AuthorityEndpoint": "https://login.microsoftonline.com/{{TenantId}}",
        "ClientId": "{{OAuthClientId}}",
        "ClientSecret": "{{OAuthClientSecret}}"
      }
    }
  },
  "ConnectionsMap": [
    {
      "ServiceUrl": "*",
      "Connection": "BlueprintConnection"
    }
  ],

  "Logging": {
    "Debug": {
      "IncludeScopes": true
    },
    "Console": {
      "IncludeScopes": true
    },
    "LogLevel": {
      "Microsoft.Agents": "Debug",
      "Microsoft.Agents.Authentication.Msal.MsalAuth": "Warning",
      "System.Net.Http.HttpClient.MSALClientFactory": "Warning",
      "System.Net.Http.HttpClient.Microsoft.Agents.Builder.RestChannelServiceClientFactory": "Warning",
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Identity": "Warning"
    }
  }
}
